{
    "Urls": "http://localhost:5000;https://localhost:5001",
    "Logging": {
        "LogLevel": {
            "Default": "Information",
            "Microsoft": "Warning",
            "Microsoft.Hosting.Lifetime": "Information"
        }
    },
    "AllowedHosts": "*",
    "JwtSettings": {
        "Authority": "https://localhost:7027"
    },
    "ReverseProxy": {
        "Routes": {
            "auth-route": {
                "ClusterId": "admin-cluster",
                "Match": {
                    "Path": "/connect/{**catch-all}"
                }
            },
            "api-route": {
                "ClusterId": "admin-cluster",
                "Match": {
                    "Path": "/api/{**catch-all}"
                }
            },
            "hangfire-route": {
                "ClusterId": "admin-cluster",
                "Match": {
                    "Path": "/hangfire/{**catch-all}"
                }
            },
            "notification-route": {
                "ClusterId": "signalr-cluster",
                "Match": {
                    "Path": "/notificationHub/{**catch-all}"
                }
            }
        },
        "Clusters": {
            "admin-cluster": {
                "Destinations": {
                    "admin-service": {
                        "Address": "https://localhost:7027/"
                    }
                }
            },
            "signalr-cluster": {
                "Destinations": {
                    "signalr-service": {
                        "Address": "http://localhost:5063/"
                    }
                }
            }
        }
    }
}