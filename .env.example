# Copy file này thành .env và điền đầy đủ giá trị trước khi chạy docker compose
# KHÔNG commit file .env lên Git — chỉ commit .env.example

# ================================================
# DATABASE CONFIG
# ================================================
DB_HOST=postgres
DB_PORT=5432
DB_NAME=Host
DB_USER=postgres
DB_PASSWORD=

# ================================================
# PORTS — ánh xạ ra ngoài máy host
# ================================================
PORT_POSTGRES=5433
PORT_ADMIN=7028
PORT_GATEWAY=5002
PORT_SIGNALR=5003
PORT_FRONTEND=3001
PORT_SEQ_UI=5341
PORT_SEQ_INGEST=5342

# ================================================
# ASPNETCORE
# ================================================
ASPNETCORE_ENVIRONMENT=Production

# ================================================
# SEQ LOGGING
# ================================================
SEQ_URL=http://seq:5341

# ================================================
# URLS NỘI BỘ — container gọi nhau qua tên service
# ================================================
ADMIN_INTERNAL_URL=http://admin-service:8080
SIGNALR_INTERNAL_URL=http://signalr:8080
GATEWAY_INTERNAL_URL=http://gateway:8080

# Additional Settings
NEXT_TELEMETRY_DISABLED=1
DOTNET_URLS=http://+:8080

# ================================================
# MINIO FILE STORAGE
# ================================================
MINIO_USER=minioadmin
MINIO_PASSWORD=
PORT_MINIO_API=9000
PORT_MINIO_CONSOLE=9001
PORT_FILE_SERVICE=6000
ALLOWED_ORIGINS=http://localhost:3000

# ================================================
# JWT / OIDC
# ================================================
JWT_SECRET=
JWT_ISSUER=
JWT_AUDIENCE=
JWT_EXPIRY_MINUTES=60

# ================================================
# OPENIDDICT / AUTH
# ================================================
AUTH_ENDPOINT=/connect/token
